# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets out of git, but commit the example)
.env
.env.*
!.env.example

# attached plaintext key files (secrets now live in .env)
*Details.txt

# personal credential notes (keep real passwords out of git)
mycreds.txt
*creds*.txt

# vercel
.vercel

# local tooling (Claude Code preview config + local settings)
.claude/

# personal data (your own watch history; keep it off a public repo)
/data/*.xlsx

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
